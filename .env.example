# Copy this file to `.env` and replace the placeholder values.
# The app will read these values locally before falling back to appsettings.json.

ConnectionStrings__SupabaseConnection=Host=YOUR_SUPABASE_HOST;Port=5432;Database=postgres;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Require;Trust Server Certificate=true;Timeout=5;Command Timeout=10;

EmailSettings__SmtpServer=smtp-relay.brevo.com
EmailSettings__Port=587
EmailSettings__SenderName=Imajination Accounts
EmailSettings__SenderEmail=YOUR_VERIFIED_SENDER_EMAIL
EmailSettings__Username=YOUR_BREVO_SMTP_USERNAME
EmailSettings__Password=YOUR_BREVO_SMTP_PASSWORD

PayMongo__SecretKey=sk_test_YOUR_PAYMONGO_SECRET_KEY

AppSecurity__AllowedOrigins__0=http://localhost:5248
AppSecurity__AllowedOrigins__1=https://localhost:5248
AppSecurity__AllowedOrigins__2=https://imajination.infinityfreeapp.com
AppSecurity__AllowedOrigins__3=https://YOUR-PROJECT.vercel.app
